default_platform(:ios)

platform :ios do
  desc "Build the app"
  lane :build do
    build_app(
      project: "MistyisletPass.xcodeproj",
      scheme: "MistyisletPass",
      clean: true,
      export_method: "app-store"
    )
  end

  desc "Run unit tests"
  lane :test do
    run_tests(
      project: "MistyisletPass.xcodeproj",
      scheme: "MistyisletPass",
      devices: ["iPhone 17 Pro"],
      clean: true
    )
  end

  desc "Upload to TestFlight"
  lane :beta do
    build
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Submit to App Store"
  lane :release do
    build
    upload_to_app_store(
      force: true,
      submit_for_review: true,
      automatic_release: false
    )
  end
end
